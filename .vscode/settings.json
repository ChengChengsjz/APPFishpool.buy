{
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.import.gradle.enabled": true,
    "java.import.gradle.wrapper.enabled": true,
    "java.import.gradle.version": "7.6.4",
    "java.jdt.ls.vmargs": "-Xmx2G",
    "java.compile.nullAnalysis.mode": "automatic",
    "java.project.sourcePaths": ["app/src/main/java"],
    "java.project.outputPath": "app/build/intermediates/javac",
    "java.project.referencedLibraries": [
        "app/libs/**/*.jar",
        "app/build/intermediates/compile_only/**/*.jar"
    ],
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/build": true,
        "**/.gradle": true,
        "**/.idea": true
    },
    "editor.formatOnSave": true,
    "java.format.settings.url": ".vscode/java-formatter.xml",
    "xml.format.enabled": true,
    "android-sdk.path": "C:\\Users\\ChengCheng\\AppData\\Local\\Android\\Sdk"
}